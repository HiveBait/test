# npm Configuration - Supply Chain Security
# Deploy this to: ~/.npmrc (user) or project root (per-project)

# Block packages published within last 7 days
min-release-age=7

# Optional: Enforce audit before install
audit-level=moderate

# Optional: Disable automatic package updates
save-exact=true

# Documentation: https://docs.npmjs.com/cli/v10/using-npm/config
